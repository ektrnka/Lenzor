<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Р Р€Р Р†Р ВµР Т‘Р С•Р СР В»Р ВµР Р…Р С‘РЎРЏ (Android 13+ РЎвЂљРЎР‚Р ВµР В±РЎС“Р ВµРЎвЂљ РЎРЏР Р†Р Р…Р С•Р С–Р С• РЎР‚Р В°Р В·РЎР‚Р ВµРЎв‚¬Р ВµР Р…Р С‘РЎРЏ) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <!-- Р вЂ™Р С‘Р В±РЎР‚Р В°РЎвЂ Р С‘РЎРЏ Р Т‘Р В»РЎРЏ РЎС“Р Р†Р ВµР Т‘Р С•Р СР В»Р ВµР Р…Р С‘Р в„– -->
    <uses-permission android:name="android.permission.VIBRATE"/>
    <!-- Р СћР С•РЎвЂЎР Р…РЎвЂ№Р Вµ РЎС“Р Р†Р ВµР Т‘Р С•Р СР В»Р ВµР Р…Р С‘РЎРЏ Р С• Р В·Р В°Р СР ВµР Р…Р Вµ Р В»Р С‘Р Р…Р В· (Android 12+) -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"/>
    <!-- Р С’Р Р†РЎвЂљР С•Р СР В°РЎвЂљР С‘РЎвЂЎР ВµРЎРѓР С”Р С•Р Вµ РЎР‚Р В°Р В·РЎР‚Р ВµРЎв‚¬Р ВµР Р…Р С‘Р Вµ Р Т‘Р В»РЎРЏ Р С—РЎР‚Р С‘Р В»Р С•Р В¶Р ВµР Р…Р С‘Р в„–-Р Р…Р В°Р С—Р С•Р СР С‘Р Р…Р В°Р Р…Р С‘Р в„– (Android 13+) -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM"/>
    <!-- Р СџР ВµРЎР‚Р ВµР С—Р В»Р В°Р Р…Р С‘РЎР‚Р С•Р Р†Р В°Р Р…Р С‘Р Вµ Р С—Р С•РЎРѓР В»Р Вµ Р С—Р ВµРЎР‚Р ВµР В·Р В°Р С–РЎР‚РЎС“Р В·Р С”Р С‘ -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    <!-- AlarmManager РІР‚вЂќ Р Т‘Р В»РЎРЏ Р Р…Р В°Р Т‘РЎвЂР В¶Р Р…РЎвЂ№РЎвЂ¦ Р В·Р В°Р С—Р В»Р В°Р Р…Р С‘РЎР‚Р С•Р Р†Р В°Р Р…Р Р…РЎвЂ№РЎвЂ¦ РЎС“Р Р†Р ВµР Т‘Р С•Р СР В»Р ВµР Р…Р С‘Р в„– -->
    <uses-permission android:name="android.permission.WAKE_LOCK"/>
    <!-- Р ВРЎРѓР С”Р В»РЎР‹РЎвЂЎР ВµР Р…Р С‘Р Вµ Р С‘Р В· Р С•Р С—РЎвЂљР С‘Р СР С‘Р В·Р В°РЎвЂ Р С‘Р С‘ Р В±Р В°РЎвЂљР В°РЎР‚Р ВµР С‘ РІР‚вЂќ Р Т‘Р В»РЎРЏ Р Р…Р В°Р С—Р С•Р СР С‘Р Р…Р В°Р Р…Р С‘Р в„– Р С—РЎР‚Р С‘ Р В·Р В°Р С”РЎР‚РЎвЂ№РЎвЂљР С•Р С Р С—РЎР‚Р С‘Р В»Р С•Р В¶Р ВµР Р…Р С‘Р С‘ -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"/>
    <application
        android:label="@string/app_name"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
        <!-- Receiver Р Т‘Р В»РЎРЏ Р С—Р С•Р С”Р В°Р В·Р В° Р В·Р В°Р С—Р В»Р В°Р Р…Р С‘РЎР‚Р С•Р Р†Р В°Р Р…Р Р…РЎвЂ№РЎвЂ¦ РЎС“Р Р†Р ВµР Т‘Р С•Р СР В»Р ВµР Р…Р С‘Р в„– (AlarmManager РІвЂ вЂ™ РЎРЊРЎвЂљР С•РЎвЂљ receiver) -->
        <receiver
            android:name="com.dexterous.flutterlocalnotifications.ScheduledNotificationReceiver"
            android:exported="false" />
        <!-- Receiver Р Т‘Р В»РЎРЏ Р С”Р Р…Р С•Р С—Р С•Р С” РЎС“Р Р†Р ВµР Т‘Р С•Р СР В»Р ВµР Р…Р С‘Р в„– (Р вЂ”Р В°Р СР ВµР Р…Р С‘Р В»Р В° Р В»Р С‘Р Р…Р В·РЎвЂ№, Р СњР В°Р С—Р С•Р СР Р…Р С‘РЎвЂљРЎРЉ Р С—Р С•Р В·Р В¶Р Вµ) -->
        <receiver
            android:name="com.dexterous.flutterlocalnotifications.ActionBroadcastReceiver"
            android:exported="false" />
        <!-- Р СџР ВµРЎР‚Р ВµР С—Р В»Р В°Р Р…Р С‘РЎР‚Р С•Р Р†Р В°Р Р…Р С‘Р Вµ РЎС“Р Р†Р ВµР Т‘Р С•Р СР В»Р ВµР Р…Р С‘Р в„– Р С—Р С•РЎРѓР В»Р Вµ Р С—Р ВµРЎР‚Р ВµР В·Р В°Р С–РЎР‚РЎС“Р В·Р С”Р С‘ -->
        <receiver
            android:name="com.dexterous.flutterlocalnotifications.ScheduledNotificationBootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED"/>
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON"/>
            </intent-filter>
        </receiver>
        <!-- Р вЂ™Р С‘Р Т‘Р В¶Р ВµРЎвЂљ Р’В«Р вЂќР С• Р В·Р В°Р СР ВµР Р…РЎвЂ№ Р В»Р С‘Р Р…Р В·Р’В» (РЎР‚Р В°Р В±Р С•РЎвЂЎР С‘Р в„– РЎРѓРЎвЂљР С•Р В») -->
        <receiver
            android:name=".LensWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE"/>
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/lens_widget_info"/>
        </receiver>
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>



